%%{init: {'theme': 'default'}}%%
flowchart LR
    subgraph KNOW["Knowledge Layer"]
        K1[Organizational<br/>Principles]
        K2[Business Rules]
        K3[Process Docs]
        K4[Domain Knowledge]
    end

    subgraph GOV["Governance Layer"]
        G1[Agent Scope<br/>Definition]
        G2[Escalation<br/>Rules]
        G3[Human<br/>Owner]
    end

    subgraph GEN["Generation Layer"]
        P1[Prompt with<br/>Knowledge Context]
        P2[AI Model<br/>Reasoning]
        P3[Structured<br/>Output]
    end

    subgraph EXEC["Execution Layer"]
        EX1[Human<br/>Review]
        EX2{Approved?}
        EX3[Action in<br/>Enterprise System]
        EX4[Escalate /<br/>Revise]
    end

    K1 & K2 & K3 & K4 --> G1
    G1 --> G2
    G2 --> G3
    G1 --> P1
    G2 --> P1
    P1 --> P2
    P2 --> P3
    P3 --> EX1
    EX1 --> EX2
    EX2 -->|Yes| EX3
    EX2 -->|No| EX4
    EX4 --> P1

    style KNOW fill:#dbeafe,stroke:#3b82f6
    style GOV fill:#fef9c3,stroke:#ca8a04
    style GEN fill:#dcfce7,stroke:#16a34a
    style EXEC fill:#fce7f3,stroke:#db2777
